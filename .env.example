# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key

# ── Patient Portal ────────────────────────────────────────────────────────────
PATIENT_JWT_SECRET=your-jwt-secret

# ── Status Page ───────────────────────────────────────────────────────────────
# Minimum number of calls before error-rate classification kicks in (default: 5)
STATUS_MIN_SAMPLE_THRESHOLD=5

# ── Deploy Webhook ────────────────────────────────────────────────────────────
DEPLOY_WEBHOOK_SECRET=your-deploy-webhook-secret

# ── Ops / Alerts ──────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
